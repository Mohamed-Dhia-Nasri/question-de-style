# ---------------------------------------------------------------------------
# Question de Style (QDS) — environment template. NO SECRETS in this file.
# Copy to .env and fill in real values. See README.md for setup instructions.
# Deployment target: Docker on Hetzner (EU), database on Neon Postgres (EU)
# per ADR-0013 (docs/05-decisions/decision-log.md#adr-0013).
# ---------------------------------------------------------------------------

APP_NAME="Question de Style"
APP_ENV=local
APP_KEY=
# Previous APP_KEYs (comma-separated) kept readable during key rotation.
# Never delete a key that still protects encrypted data.
APP_PREVIOUS_KEYS=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Build metadata surfaced by /health (set by CI/CD in production).
QDS_BUILD_SHA=
QDS_BUILD_TIME=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_DE

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (PostgreSQL only; Neon in production — TLS required) ----------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
# Local docker-compose maps the qds-postgres container to 5433.
DB_PORT=5433
DB_DATABASE=qds
DB_USERNAME=qds
# Matches the local docker-compose default (not a secret). Production uses
# the Neon connection credentials from the deployment environment.
DB_PASSWORD=qds
# Production (Neon): DB_SSLMODE=require
DB_SSLMODE=prefer

# --- Sessions / cache / queue ------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production: SESSION_SECURE_COOKIE=true
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# database queue locally; switch to redis in production (Horizon-ready).
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
# The optional local redis container maps to 6380 (docker compose --profile
# redis up -d); production Redis uses its own host/port.
REDIS_PORT=6380

# --- Mail (log driver locally; real SMTP creds via secrets in production) ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="qds@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- QDS platform toggles ----------------------------------------------------
# Snapshot scheduler (SVC-SnapshotScheduler, ADR-0003). Requires ingested
# data to sample; snapshot cadence/spacing is configurable (no canonical
# cadence decision yet — see reviews/ handoff).
QDS_SNAPSHOTS_ENABLED=false
# QDS_SNAPSHOTS_MIN_INTERVAL_MINUTES=55
# QDS_SNAPSHOTS_CONTENT_WINDOW_DAYS=30
# Analytics rollup refresh (SVC-Analytics, ADR-0010/ADR-0013) — enable once
# FACT-*/ROLLUP-* structures exist.
QDS_ANALYTICS_ROLLUP_REFRESH_ENABLED=false

# --- SVC-Ingestion (frozen SRC-* providers, ADR-0001/0002) --------------------
# Master switch for the recurring roster monitoring cycles.
QDS_INGESTION_ENABLED=false
# Poll cadences (cron) — configurable because no canonical decision fixes
# them; stories default tighter because they expire (REQ-M1-004).
# QDS_INGESTION_CYCLE_CRON="0 */6 * * *"
# QDS_INGESTION_STORY_CYCLE_CRON="30 */4 * * *"
# QDS_INGESTION_CONTENT_LIMIT=30
# Private media archive disk (stories): local for dev; s3-compatible
# (Hetzner Object Storage / R2) in production via QDS_MEDIA_* below.
# QDS_MEDIA_DISK=media
# QDS_MEDIA_DRIVER=local
# QDS_MEDIA_S3_KEY= / QDS_MEDIA_S3_SECRET= / QDS_MEDIA_S3_REGION= /
# QDS_MEDIA_S3_BUCKET= / QDS_MEDIA_S3_ENDPOINT=
# QDS_MEDIA_SIGNED_URL_TTL_MINUTES=10
# Response sampling for debugging (redacted, short retention, ADMIN-only).
# QDS_INGESTION_SAMPLING_ENABLED=false

# Apify (Instagram actors + the sole TikTok source). Secret token — set in
# the deployment environment, NEVER commit a real value.
APIFY_TOKEN=
# YouTube Data API v3 key (public statistics only, DEF-004). Secret.
YOUTUBE_API_KEY=

# --- SVC-EnrichmentAI (frozen SRC-google-* providers, ADR-0001) ---------------
# Master switch for the recurring enrichment sweep (hashtags, recognition,
# sentiment boundary, seeded attribution, EMV).
QDS_ENRICHMENT_ENABLED=false
# Sweep cadence (cron) — configurable because no canonical decision fixes it.
# QDS_ENRICHMENT_SWEEP_CRON="15 */6 * * *"
# QDS_ENRICHMENT_SWEEP_BATCH=50
# QDS_ENRICHMENT_CONTENT_WINDOW_DAYS=30
# Provider-score → ConfidenceLevel cut-points (flagged missing decision).
# QDS_ENRICHMENT_CONFIDENCE_HIGH=0.85
# QDS_ENRICHMENT_CONFIDENCE_MEDIUM=0.60
# Shipment→content attribution window in days (flagged missing decision).
# QDS_ENRICHMENT_SHIPMENT_WINDOW_DAYS=60
# MET-EngagementRate divisor model: followers | views (disclosed in reports).
# QDS_ENRICHMENT_ENGAGEMENT_BASE=followers

# Google AI recognition credentials (SRC-google-cloud-vision /
# SRC-google-speech-to-text / SRC-google-video-intelligence). Secrets — a
# provider with no key is skipped and its outputs stay unavailable.
GOOGLE_VISION_API_KEY=
GOOGLE_SPEECH_API_KEY=
# Optional deep video pass (data-source matrix marks it OPTIONAL).
GOOGLE_VIDEO_INTELLIGENCE_API_KEY=

# Google Embeddings (SRC-google-gemini-embeddings, sub-project C / ADR-0029)
# service-account JSON path + project — templated late (C gap): required for
# visual product matching. Secrets — never commit real values.
GOOGLE_EMBEDDINGS_CREDENTIALS=
GOOGLE_EMBEDDINGS_PROJECT=

# --- Sub-project D: VLM verification + multilingual speech (ADR-0030) --------
# Both features ship dark; each switch is a true no-op while false.
# VLM verification (SRC-google-gemini-vlm) — gemini-3.5-flash on the EU
# endpoint. Service-account JSON path + project id; may reuse the embeddings
# service-account key. Secrets — never commit real values.
QDS_ENRICHMENT_VLM_ENABLED=false
GOOGLE_VLM_CREDENTIALS=
GOOGLE_VLM_PROJECT=
# GOOGLE_VLM_LOCATION=eu
# QDS_ENRICHMENT_VLM_MODEL=gemini-3.5-flash
# QDS_ENRICHMENT_VLM_QUEUE=enrichment
# QDS_ENRICHMENT_VLM_FRAME_BUDGET=12
# Multilingual speech (Speech-to-Text v2, chirp_3, EU multi-region). OFF =
# the byte-identical legacy v1 path (de-DE, <=60s, GOOGLE_SPEECH_API_KEY).
# NOTE: v2 has no free tier — chunk 0 meters every audio-bearing post.
QDS_ENRICHMENT_SPEECH_V2_ENABLED=false
GOOGLE_SPEECH_V2_CREDENTIALS=
GOOGLE_SPEECH_V2_PROJECT=
# GOOGLE_SPEECH_V2_LOCATION=eu
# QDS_ENRICHMENT_SPEECH_CHUNK_SECONDS=55
# QDS_ENRICHMENT_SPEECH_MAX_MINUTES=10

# --- Billing (ADR-0021) --------------------------------------------------------
# Stripe secrets — set in the deployment environment, NEVER commit real values.
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# Stripe price ids for the plan catalog (config/billing.php). A plan with no
# price id is catalogued but not purchasable.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_AGENCY=
# Server-side subscription + seat enforcement. OFF until commercial launch:
# the founding tenant predates billing (flip on once its subscription exists).
QDS_BILLING_ENFORCED=false
# QDS_BILLING_INVITATION_EXPIRY_DAYS=7
# Seat allowances per plan (final commercial values pending — ADR-0021).
# QDS_BILLING_STARTER_SEATS=5
# QDS_BILLING_GROWTH_SEATS=15
# QDS_BILLING_AGENCY_SEATS=40

# --- Personal-data protection ------------------------------------------------
# Keyed blind-index hashing for exact lookup over encrypted personal data.
# Generate with: php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
# NEVER commit a real key. Distinct from APP_KEY so either can rotate alone.
QDS_BLIND_INDEX_KEY=

VITE_APP_NAME="${APP_NAME}"
